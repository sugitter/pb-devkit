<?xml version="1.0" encoding="UTF-8"?>
<idea-plugin>
    <id>com.pbdevkit.powerscript</id>
    <name>PowerScript (PowerBuilder)</name>
    <vendor>pb-devkit</vendor>
    <version>1.0.0</version>
    <description><![CDATA[
        PowerScript language support for PowerBuilder .sr* source files.
        <br/>
        Features: Syntax highlighting, Lint diagnostics, Code completion, Hover documentation.
    ]]></description>
    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <!-- File type registration -->
        <fileType name="PowerScript" implementationClass="com.pbdevkit.powerscript.PSFileType"
                  language="PowerScript" extensions="srw;sru;srd;srf;srm;sra;srs;srq;srp;srj;srx;sre;src"/>
        <lang.parserDefinition language="PowerScript"
                               implementationClass="com.pbdevkit.powerscript.PSParserDefinition"/>
        <lang.syntaxHighlighterFactory language="PowerScript"
                                       implementationClass="com.pbdevkit.powerscript.PSSyntaxHighlighterFactory"/>

        <!-- Code folding -->
        <lang.foldingBuilder language="PowerScript"
                             implementationClass="com.pbdevkit.powerscript.PSFoldingBuilder"/>

        <!-- Brace matcher -->
        <lang.braceMatcher language="PowerScript"
                           implementationClass="com.pbdevkit.powerscript.PSBraceMatcher"/>

        <!-- Commenter -->
        <lang.commenter language="PowerScript" implementationClass="com.pbdevkit.powerscript.PSCommenter"/>

        <!-- Auto-indent -->
        <lang.indentStrategy language="PowerScript"
                             implementationClass="com.pbdevkit.powerscript.PSIndentStrategy"/>

        <!-- Completion -->
        <completion.contributor language="PowerScript"
                                implementationClass="com.pbdevkit.powerscript.completion.PSCompletionContributor"/>

        <!-- Hover documentation -->
        <lang.documentationProvider language="PowerScript"
                                    implementationClass="com.pbdevkit.powerscript.hover.PSDocumentationProvider"/>

        <!-- Inspections (Lint) -->
        <localInspection language="PowerScript" groupPath="PowerScript" groupDisplayKey="powerscript.group"
                         displayName="Empty CATCH block" enabledByDefault="true" level="ERROR"
                         implementationClass="com.pbdevkit.powerscript.inspections.EmptyCatchInspection"/>
        <localInspection language="PowerScript" groupPath="PowerScript" groupDisplayKey="powerscript.group"
                         displayName="Routine too long" enabledByDefault="true" level="WARNING"
                         implementationClass="com.pbdevkit.powerscript.inspections.RoutineTooLongInspection"/>
        <localInspection language="PowerScript" groupPath="PowerScript" groupDisplayKey="powerscript.group"
                         displayName="Deep nesting" enabledByDefault="true" level="WARNING"
                         implementationClass="com.pbdevkit.powerscript.inspections.DeepNestingInspection"/>
        <localInspection language="PowerScript" groupPath="PowerScript" groupDisplayKey="powerscript.group"
                         displayName="High cyclomatic complexity" enabledByDefault="true" level="WARNING"
                         implementationClass="com.pbdevkit.powerscript.inspections.HighComplexityInspection"/>
        <localInspection language="PowerScript" groupPath="PowerScript" groupDisplayKey="powerscript.group"
                         displayName="Deprecated function" enabledByDefault="true" level="WARNING"
                         implementationClass="com.pbdevkit.powerscript.inspections.DeprecatedFunctionInspection"/>
        <localInspection language="PowerScript" groupPath="PowerScript" groupDisplayKey="powerscript.group"
                         displayName="Hardcoded SQL" enabledByDefault="true" level="WARNING"
                         implementationClass="com.pbdevkit.powerscript.inspections.HardcodedSqlInspection"/>
        <localInspection language="PowerScript" groupPath="PowerScript" groupDisplayKey="powerscript.group"
                         displayName="SELECT *" enabledByDefault="true" level="WARNING"
                         implementationClass="com.pbdevkit.powerscript.inspections.SelectStarInspection"/>
        <localInspection language="PowerScript" groupPath="PowerScript" groupDisplayKey="powerscript.group"
                         displayName="Global variable usage" enabledByDefault="true" level="WEAK_WARNING"
                         implementationClass="com.pbdevkit.powerscript.inspections.GlobalVariableInspection"/>
        <localInspection language="PowerScript" groupPath="PowerScript" groupDisplayKey="powerscript.group"
                         displayName="No error handling" enabledByDefault="true" level="WEAK_WARNING"
                         implementationClass="com.pbdevkit.powerscript.inspections.NoErrorHandlingInspection"/>
        <localInspection language="PowerScript" groupPath="PowerScript" groupDisplayKey="powerscript.group"
                         displayName="Magic numbers" enabledByDefault="true" level="WEAK_WARNING"
                         implementationClass="com.pbdevkit.powerscript.inspections.MagicNumbersInspection"/>
    </extensions>

    <actions>
        <action id="PowerScript.RunLintFile"
                class="com.pbdevkit.powerscript.actions.RunLintFileAction"
                text="Run PowerScript Lint on File"
                description="Run lint on the current PowerScript file">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
    </actions>

    <extensionPoints>
        <extensionPoint name="PowerScript Notifications" interface="com.intellij.notification.NotificationGroup"/>
    </extensionPoints>

    <extensions defaultExtensionNs="com.intellij">
        <notificationGroup id="PowerScript Notifications"
                           displayType="BALLOON"/>
    </extensions>

    <application-components>
        <component>
            <implementation-class>com.pbdevkit.powerscript.PSApplicationComponent</implementation-class>
        </component>
    </applicationComponents>
</idea-plugin>
