{
  "comments": {
    "lineComment": "//",
    "blockComment": ["/*", "*/"]
  },
  "brackets": [
    ["(", ")"],
    ["[", "]"],
    ["BEGIN", "END"],
    ["if", "end if"],
    ["for", "next"],
    ["do", "loop"],
    ["choose", "end choose"],
    ["try", "end try"]
  ],
  "autoClosingPairs": [
    { "open": "(", "close": ")" },
    { "open": "[", "close": "]" },
    { "open": "\"", "close": "\"", "notIn": ["string"] },
    { "open": "'", "close": "'", "notIn": ["string", "comment"] }
  ],
  "surroundingPairs": [
    { "open": "(", "close": ")" },
    { "open": "[", "close": "]" },
    { "open": "\"", "close": "\"" },
    { "open": "'", "close": "'" }
  ],
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_#!]*",
  "indentationRules": {
    "increaseIndentPattern": "\\b(if|for|do|try|choose\\s+case|else|elseif|catch|finally)\\b.*$",
    "decreaseIndentPattern": "^\\s*(end\\s+(if|for|do|try|choose)|next|loop|catch|finally|else|elseif)\\b"
  },
  "folding": {
    "markers": {
      "start": "^\\s*(?:(?:public|private|protected|global)\\s+)?(?:subroutine|function)\\b",
      "end": "^\\s*end\\s+(?:subroutine|function)\\b"
    }
  },
  "onEnterRules": [
    {
      "beforeText": "\\b(if|for|do|try|choose\\s+case)\\b.*then\\s*$",
      "afterText": "^\\s*$",
      "action": { "indent": "indent" }
    },
    {
      "beforeText": "^\\s*(end\\s+(if|for|do|try|choose)|next|loop)\\b",
      "action": { "indent": "outdent" }
    }
  ]
}
