{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "PowerScript",
  "scopeName": "source.powerscript",
  "fileTypes": ["srw", "sru", "srd", "srf", "srm", "sra", "srs", "srq", "srp", "srj", "srx", "sre", "src"],
  "patterns": [
    { "include": "#pb-export-header" },
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#embedded-sql" },
    { "include": "#dwo-expressions" },
    { "include": "#dot-access" },
    { "include": "#function-call" },
    { "include": "#keywords" },
    { "include": "#type-keywords" },
    { "include": "#access-modifiers" },
    { "include": "#declarations" },
    { "include": "#pb-constants" },
    { "include": "#variables" }
  ],
  "repository": {
    "pb-export-header": {
      "match": "^\\$PBExportHeader\\$.+",
      "name": "comment.block.powerscript.header"
    },
    "comments": {
      "patterns": [
        {
          "match": "//.*$",
          "name": "comment.line.double-slash.powerscript"
        },
        {
          "begin": "/\\*",
          "end": "\\*/",
          "name": "comment.block.powerscript"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "begin": "\"",
          "end": "\"",
          "name": "string.quoted.double.powerscript",
          "patterns": [
            {
              "match": "~[nrtd0\"~]",
              "name": "constant.character.escape.powerscript"
            }
          ]
        },
        {
          "begin": "'",
          "end": "'",
          "name": "string.quoted.single.powerscript",
          "patterns": [
            {
              "match": "~[nrtd0\"~]",
              "name": "constant.character.escape.powerscript"
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "match": "\\b-?\\d+\\.?\\d*([eE][+-]?\\d+)?\\b",
          "name": "constant.numeric.powerscript"
        },
        {
          "match": "\\b0[xX][0-9a-fA-F]+\\b",
          "name": "constant.numeric.hex.powerscript"
        }
      ]
    },
    "embedded-sql": {
      "patterns": [
        {
          "begin": "\\b(SELECT|INSERT|UPDATE|DELETE|DECLARE|FETCH|CLOSE|OPEN|EXEC(?:UTE)?)\\b",
          "end": "(?=^\\s*(end\\s+(if|for|do|try|choose|function|subroutine|event)|on\\s+|public\\s+|private\\s+|protected\\s+|global\\s+))",
          "name": "meta.embedded.sql.powerscript",
          "patterns": [
            { "include": "#sql-keywords" },
            { "include": "#comments" },
            { "include": "#strings" }
          ]
        }
      ]
    },
    "sql-keywords": {
      "match": "\\b(SELECT|FROM|WHERE|INTO|VALUES|SET|INSERT|UPDATE|DELETE|JOIN|LEFT|RIGHT|INNER|OUTER|FULL|CROSS|ON|AND|OR|NOT|IN|EXISTS|BETWEEN|LIKE|ORDER|BY|GROUP|HAVING|UNION|ALL|DISTINCT|AS|ASC|DESC|NULL|IS|COUNT|SUM|AVG|MIN|MAX|CREATE|DROP|ALTER|TABLE|INDEX|VIEW|PROCEDURE|TRIGGER|EXECUTE|IMMEDIATE|USING|DYNAMIC|CURSOR|FOR|READ|ONLY|FETCH|NEXT|PRIOR|FIRST|LAST|CLOSE|OPEN|DECLARE|SECTION|CONNECT|DISCONNECT|COMMIT|ROLLBACK|TRANSACTION|BEGIN|TRANSACTION|DATABASE|POWERBUILDER)\\b",
      "name": "keyword.sql.powerscript"
    },
    "dwo-expressions": {
      "match": "(\\b\\w+\\s*\\.)(Object|Data|Buffer|Modify|Describe|InsertRow|DeleteRow|SetFilter|SetSort|Retrieve|Update|Reset|RowsMove|RowsCopy|RowsDiscard|GetItemString|GetItemNumber|GetItemDate|GetItemDateTime|SetItem|SetColumn|SetText|GetText|IsSelected|SelectRow|GroupCalc|ShareData|GetChild|GetSQLSelect|SetSQLSelect|ImportString|ImportFile|Export|Save|Print|SetTransObject|SetTrans)\\b",
      "captures": {
        "1": { "name": "variable.other.object.powerscript" },
        "2": { "name": "support.function.dw.powerscript" }
      }
    },
    "dot-access": {
      "match": "(\\b\\w+)\\.(\\w+)\\b",
      "captures": {
        "1": { "name": "variable.other.object.powerscript" },
        "2": { "name": "variable.other.property.powerscript" }
      }
    },
    "function-call": {
      "match": "\\b([a-zA-Z_]\\w*)\\s*(?=\\()",
      "captures": {
        "1": { "name": "entity.name.function.powerscript" }
      }
    },
    "keywords": {
      "patterns": [
        {
          "match": "\\b(if|then|else|elseif|end\\s+if|choose|case|end\\s+choose|for|to|step|next|do|while|until|loop|end\\s+loop|continue|exit|return|goto|try|catch|finally|end\\s+try|throw|create|destroy|call|super|parent|this|post|dynamic|not|and|or|is|null|true|false|to|using|within|from|global|type|end\\s+type|forward|end\\s+forward|event|end\\s+event|on|end\\s+on|prototype|end\\s+prototype|prototypes|variables|end\\s+variables)\\b",
          "name": "keyword.control.powerscript"
        }
      ]
    },
    "type-keywords": {
      "match": "\\b(integer|int|long|longlong|ulong|uint|dec|decimal|real|double|string|blob|char|nchar|date|time|datetime|boolean|any|unsigned|window|menu|datawindow|datastore|commandbutton|singlelineedit|multilineedit|dropdownlistbox|dropdownlistpicture|picture|picturebutton|graph|progressbar|hscrollbar|vscrollbar|tab|userobject|nonvisualobject|transaction|pipe|structure|enumeration|connection|internetresult|oleobject|olestream|mailsession|mailmessage|tracetree|timing|profiling|errorlogging|corbaobject|ejbobject|javabean|mdiframe|treeview|listview|datawindowchild|richTextEdit|statictext|groupbox|checkbox|radiobutton|editmask|OLEControl|OLECustomControl|OLEObject|Inet|HyperLink|Pipeline|Transaction|DataStore|DataWindowChild|PowerObject|NonVisualObject|SystemFunctions|FunctionKeyword|SubroutineKeyword)\\b",
      "name": "support.type.powerscript"
    },
    "access-modifiers": {
      "match": "\\b(public|private|protected|shared|instance|global|read-only|readonly|constant|autoinstantiate)\\b",
      "name": "storage.modifier.powerscript"
    },
    "declarations": {
      "patterns": [
        {
          "match": "^\\s*(?:(forward\\s+)?(?:public|private|protected|global)\\s+)?(?:subroutine|function)\\s+(?:(?:\\w+\\s+)?)\\b(\\w+)\\b",
          "captures": {
            "1": { "name": "entity.name.function.powerscript" }
          }
        },
        {
          "match": "^\\s*(?:(?:public|private|protected|shared|instance|global)\\s+)?(\\w+)\\s+(\\w+)\\s*(?:\\[\\s*\\])?(?:\\s*=|\\s*;|$)",
          "captures": {
            "1": { "name": "support.type.powerscript" },
            "2": { "name": "variable.other.powerscript" }
          }
        },
        {
          "match": "^\\s*(?:global\\s+)?type\\s+(\\w+)\\s+from\\s+(\\w+)",
          "captures": {
            "1": { "name": "entity.name.type.powerscript" },
            "2": { "name": "entity.other.inherited-class.powerscript" }
          }
        },
        {
          "match": "^\\s*on\\s+(\\w+)\\.(\\w+)",
          "captures": {
            "1": { "name": "entity.name.type.powerscript" },
            "2": { "name": "entity.name.function.event.powerscript" }
          }
        }
      ]
    },
    "pb-constants": {
      "match": "\\b(HourGlass!|Arrow!|Cross!|Beam!|Size!|SizeNS!|SizeWE!|SizeNWSE!|SizeNESW!|HyperLink!|APPEND!|CHOOSE!|CREATE!|DELETE!|FILTER!|INSERT!|MODIFY!|RETRIEVE!|UPDATE!|CANCEL!|CLOSE!|DBCANCEL!|DBE!|EOF!|NOTMODIFIED!|OK!|PROMPT!|SETCODE!|SETFOCUS!|USERDEFINED!|ANY!|CHAR!|DATE!|DATETIME!|DECIMAL!|DOUBLE!|INTEGER!|LONG!|REAL!|STRING!|TIME!|UNSIGNEDINTEGER!|UNSIGNEDLONG!|TRUE|FALSE|YES!|NO!)\\b",
      "name": "constant.language.powerscript"
    },
    "variables": {
      "match": "\\b(sqlca|sqlsa|sqlda|sqlcode|sqldbcode|sqlnrows|sqlerrtext|sqlreturndata|transaction)\\b",
      "name": "variable.language.powerscript"
    }
  }
}
